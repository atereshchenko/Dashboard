@model IEnumerable<Dashboard.Models.Tile>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container g-3 py-3" id="featured-3">
    @*<h3 class="pb-2 border-bottom">Закладки</h3>*@    
    <div class="row g-3 py-3 row-cols-1 row-cols-lg-5">
        @foreach (var tile in Model)
        {
            <div class="col">
				<div class="card shadow-sm">
					<div class="card-body">
						<p class="card-text">@tile.Name</p>
						<p class="card-text">@tile.Description</p>
						<div class="d-flex justify-content-between align-items-center">
							<div class="btn-group">								
								<a class="btn btn-sm btn-outline-secondary" href="@tile.Link" target="_blank" rel="noreferrer" role="button">@tile.LinkName</a>
							</div>							
						</div>
					</div>
				</div>
			</div>
        }
    </div>
</div>

